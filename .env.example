# ============================================
# ClawRelay WeCom Server - Environment Variables
# ============================================
# Copy this file to .env and modify as needed.
# For Docker Compose, these values are used as defaults.

# Server
PORT=5000
ENVIRONMENT=development

# Database (MySQL)
# For Docker Compose, DB_HOST is automatically set to "mysql"
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=clawrelay_wecom
DB_USERNAME=clawrelay
DB_PASSWORD=clawrelay123

# Docker Compose MySQL root password
MYSQL_ROOT_PASSWORD=clawrelay123

# Admin API Key (auto-generated if not set)
# ADMIN_API_KEY=your-api-key

# AI Configuration
WEIXIN_ENABLE_THINKING=true
WEIXIN_AGENT_ASYNC_MODE=true
WEIXIN_AGENT_TIMEOUT_SECONDS=30

# File Upload
# WEIXIN_MAX_FILE_SIZE=20971520  # 20MB default
